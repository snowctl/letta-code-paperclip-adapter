{
  "name": "letta-code-paperclip-adapter",
  "version": "0.1.1",
  "description": "Paperclip adapter for Letta Code agents",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ui-parser": {
      "bun": "./src/ui/index.ts",
      "import": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    }
  },
  "files": [
    "src/index.ts",
    "src/server",
    "src/ui",
    "src/skills",
    "dist"
  ],
  "paperclip": {
    "adapterUiParser": "1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/snowctl/letta-code-paperclip-adapter.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@letta-ai/letta-client": "^1.10.2",
    "@letta-ai/letta-code": "^0.24.0",
    "@paperclipai/adapter-utils": "2026.416.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/bun": "^1.3.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun test src/tests && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/tests"
  }
}
